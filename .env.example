# RAG API
RAG_SERVICE_API_KEY=CHANGE_ME_RAG_SERVICE_API_KEY
RAG_ADMIN_API_KEY=CHANGE_ME_RAG_ADMIN_API_KEY
RAG_SERVICE_TIMEOUT_MS=3000
RAG_DEFAULT_TOP_K=5
RAG_MAX_TOP_K=10

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_ALIAS=dalizai_knowledge_v1
QDRANT_COLLECTION_PREFIX=dalizai_knowledge
QDRANT_KEEP_COLLECTIONS=2

# Model providers
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL=qwen3.7-text-embedding
EMBEDDING_DIMENSION=1024
RERANK_PROVIDER=dashscope
RERANK_MODEL=qwen3-rerank
RERANK_MODE=qa
RERANK_TOP_N=10
QUERY_REWRITE_CHAT_MODEL=qwen-turbo
GAP_CLUSTER_CHAT_MODEL=qwen-turbo
GAP_CLUSTER_SIMILARITY_THRESHOLD=0.82
GAP_CLUSTER_BATCH_SIZE=100

# DashScope
DASHSCOPE_API_KEY=CHANGE_ME_DASHSCOPE_API_KEY
DASHSCOPE_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
DASHSCOPE_CHAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Thresholds
SUCCESS_CONFIDENCE_THRESHOLD=0.75
LOW_CONFIDENCE_THRESHOLD=0.50

# Knowledge
KNOWLEDGE_BASE_DIR=knowledge
KNOWLEDGE_VERSION=

# Metadata DB
RAG_METADATA_DB_URL=sqlite:///data/rag_service.db

# Logs and privacy
AUDIT_LOG_RETENTION_DAYS=90
KNOWLEDGE_GAP_RETENTION_DAYS=180
APP_LOG_RETENTION_DAYS=30
